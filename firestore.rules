rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Books are private per user
    match /books/{bookId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create:      if request.auth != null;
    }

    // Quotes are private per user
    match /quotes/{quoteId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create:      if request.auth != null;
    }

    // Word notes are private per user
    match /wordNotes/{noteId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create:      if request.auth != null;
    }

    // Book clubs — any authenticated user can READ or JOIN (update memberIds)
    match /bookclubs/{clubId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;

      // ANY authenticated user can update a club (needed for invite-link joining)
      // Members and owner can do full edits; outsiders can only add themselves
      allow update: if request.auth != null && (
        // Owner: full control
        resource.data.createdBy == request.auth.uid ||
        // Existing member: full control
        request.auth.uid in resource.data.memberIds ||
        // New joiner via invite: can only ADD themselves to memberIds & members
        (
          request.resource.data.keys().hasAll(resource.data.keys()) &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.auth.uid in request.resource.data.memberIds
        )
      );

      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;

      // Chat messages — only members can read/write
      match /messages/{msgId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/bookclubs/$(clubId)).data.memberIds;
      }

      // Meetings — only members can read/write
      match /meetings/{meetingId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/bookclubs/$(clubId)).data.memberIds;
      }
    }
  }
}
